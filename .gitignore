# OS and editor files
.DS_Store
.vscode/
.idea/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files
.env
.env.*
!.env.example

# Python backend
backend/.venv/
backend/__pycache__/
backend/.pytest_cache/
backend/.mypy_cache/
backend/.coverage
backend/htmlcov/
*.pyc

# Node/Next.js frontend
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.turbo/
frontend/.vercel/

# Build artifacts
dist/
build/

cat >> .gitignore << 'EOF'
# dependencies
node_modules/
**/node_modules/

# next
.next/
out/

# env
.env
.env.*

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS/editor
.DS_Store
.vscode/
EOF